# ===============================================
# BARIS FILTER GLOBAL (3 KOLOM)
# ===============================================
col1, col2, col3 = st.columns(3)

with col1:
    block_options = st.session_state.get("block_options", [])
    # REVISI FINAL: Kondisi eksplisit untuk selectbox block
