                    if fig_trend:
                        st.plotly_chart(fig_trend, use_container_width=True)

    # --- 📊 PERFORMANCE SNAPSHOT ---
    st.markdown("## 📊 Performance Snapshot")
    cols_snap = st.columns(3)
